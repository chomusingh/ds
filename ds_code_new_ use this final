        "# libraries we want to import\n",
        "!pip install nltk scikit-learn pandas\n",
        "\n",
        "\n",
        "#importing the imports\n",
        "import nltk\n",
        "import pandas as pd\n",
        "from nltk.tokenize import word_tokenize\n",
        "from nltk.corpus import stopwords\n",
        "from nltk.stem import PorterStemmer, WordNetLemmatizer\n",
        "from nltk import pos_tag\n",
        "from sklearn.feature_extraction.text import TfidfVectorizer, CountVectorizer\n",
        "\n",
        "#inside the language we have stopwords , punctuations we are downloading all of them here\n",
        "nltk.download(\"punkt\")\n",
        "nltk.download(\"punkt_tab\")\n",
        "nltk.download(\"stopwords\")\n",
        "nltk.download('averaged_perceptron_tagger')\n",
        "nltk.download('averaged_perceptron_tagger_eng')\n",
        "nltk.download(\"wordnet\")\n",
        "\n",
        "\n",
        "#this is the document which we are using to perform the experiment\n",
        "documents = [\n",
        "    \"The fox runs on the box.\",\n",
        "    \"A quick brown fox jumps over the lazy dog.\",\n",
        "    \"Natural language processing is used in AI applications.\",\n",
        "    \"Students are learning text preprocessing techniques in Python.\"\n",
        "]\n",
        "\n",
        "#tokenization here we are breaking the sentence into the single words\n",
        "print(\"----------------------------********TOKENIZATION********-----------------\")\n",
        "tokens = [word_tokenize(doc.lower()) for doc in documents]\n",
        "print(\"Tokenized Output:\")\n",
        "print(tokens)\n",
        "\n",
        "#here we are trying to find the part of speech\n",
        "print(\" \")\n",
        "print(\"-------------*******PART OF SPEECH TAGGING (POS)**************----------\")\n",
        "\n",
        "for doc_tokens in tokens:\n",
        "  print(pos_tag(doc_tokens))\n",
        "\n",
        "print(\" \")\n",
        "\n",
        "#in the language we are having words like am is are the which dont provide any meaning in nlp so we are treating them like stopwords and removing it\n",
        "print(\"-------------*******STOP WORD REMOVAL **************----------\")\n",
        "print(\" \")\n",
        "stop_words = set(stopwords.words('english'))\n",
        "cleaned_tokens = []\n",
        "for doc in tokens:\n",
        "  filtered = [word for word in doc if word.isalpha() and word not in stop_words]\n",
        "  cleaned_tokens.append(filtered)\n",
        "  print(cleaned_tokens)\n",
        "  print(\" \")\n",
        "\n",
        "#is stemming we are chopping off ends of words (e.g., \"-ing\", \"-ed\", \"-s\")\n",
        "print(\"-------------******* Stemming **************----------\")\n",
        "stemmed_output = []\n",
        "stemmer = PorterStemmer ()\n",
        "for doc in cleaned_tokens:\n",
        "  stemmed = [stemmer.stem(word) for word in doc]\n",
        "  stemmed_output.append(stemmed)\n",
        "print(f\"The stemmed output is {stemmed_output}\")\n",
        "print(\" \")\n",
        "\n",
        "# in stemming we are sticking to the root word(It maps variations like \"running,\" \"runs,\" and \"ran\" back to the root \"run,\" ensuring the output is a valid dictionary word.)\n",
        "print(\"-------------******* lemmitization **************----------\")\n",
        "print(\" \")\n",
        "lemmatizer = WordNetLemmatizer()\n",
        "lemmatized_output = []\n",
        "for doc in cleaned_tokens:\n",
        "  lemmatized = [lemmatizer.lemmatize(word) for word in doc]\n",
        "  lemmatized_output.append(lemmatized)\n",
        "  print(\"\\nLemmatized Output:\")\n",
        "  print(lemmatized_output)\n",
        "\n",
        "#TF-IDF (Term Frequency-Inverse Document Frequency) is a foundational NLP technique that converts text into numerical vectors by weighing words based on their importance.\n",
        "print(\"-------------******* TF calculation **************----------\")\n",
        "print(\"\\nTerm Frequency (TF):\")\n",
        "for i, doc in enumerate(cleaned_tokens):\n",
        "  tf = {}\n",
        "  total_words = len(doc)\n",
        "  for word in doc:\n",
        "    tf[word] = tf.get(word, 0) + 1\n",
        "  for word in tf:\n",
        "    tf[word] /= total_words\n",
        "print(f\"Document {i+1}: {tf}\")\n",
        "\n",
        "print(\"-------------******* TF IDF using Sklearn **************----------\")\n",
        "vectorizer = TfidfVectorizer()\n",
        "tfidf_matrix = vectorizer.fit_transform(documents)\n",
        "feature_names = vectorizer.get_feature_names_out()\n",
        "tfidf_df = pd.DataFrame(tfidf_matrix.toarray(), columns=feature_names)\n",
        "print(\"\\nTF-IDF Matrix:\")\n",
        "print(tfidf_df)"
      ]
